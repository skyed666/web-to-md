{
  "manifest_version": 3,
  "name": "__MSG_ext_name__",
  "version": "1.2.0",
  "description": "__MSG_ext_description__",
  "default_locale": "en",
  "author": "Shishi",
  "homepage_url": "https://github.com/skyed666/web-to-md",
  "permissions": [
    "activeTab",
    "downloads",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "https://r.jina.ai/*",
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "convert-md": {
      "suggested_key": { "default": "Ctrl+Shift+M", "mac": "Command+Shift+M" },
      "description": "__MSG_cmd_md__"
    },
    "convert-json": {
      "suggested_key": { "default": "Ctrl+Shift+J", "mac": "Command+Shift+J" },
      "description": "__MSG_cmd_json__"
    }
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "__MSG_ext_title__",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}