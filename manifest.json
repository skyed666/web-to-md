{
  "manifest_version": 3,
  "name": "网页转换器 - Markdown / JSON",
  "version": "1.0.0",
  "description": "将当前网页转换为 Markdown 或 JSON 并下载保存。",
  "author": "Shishi",
  "homepage_url": "https://github.com/skyed666/web-to-md",
  "permissions": [
    "activeTab",
    "downloads"
  ],
  "host_permissions": [
    "https://r.jina.ai/*",
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}